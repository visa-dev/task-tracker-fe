# Local development (against the backend running via docker-compose or `mvn spring-boot:run`)
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_WS_URL=http://localhost:8080/ws

# --- Production (Vercel) ---
# Don't put production values in this file - set them in the Vercel dashboard instead:
# Project -> Settings -> Environment Variables. Example values once the backend is live
# on EC2 (behind a domain/load balancer, ideally with HTTPS):
#
# VITE_API_BASE_URL=https://api.yourdomain.com/api/v1
# VITE_WS_URL=https://api.yourdomain.com/ws
#
# Also remember to add this Vercel deployment's URL to the backend's CORS_ALLOWED_ORIGINS.
